                int id = (int)dataGridView1.SelectedRows[0].Cells["Id"].Value;
                var item = Kitaplar.FirstOrDefault(x => x.Id == id);

                KitapView vwKitap = new KitapView(item);
                if (vwKitap.ShowDialog() == DialogResult.OK)
                {
                    // Kitap güncelleme işlemi (sp_kitap_guncelle)
                    uow.KitapRepository.Update(vwKitap.Kitap);
                    KitaplarSource.ResetBindings(false);
                }
            }

            var fiyatColumn = new DataGridViewTextBoxColumn() { HeaderText = "Fiyatı", DataPropertyName = "Fiyat" };
            fiyatColumn.DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
            fiyatColumn.DefaultCellStyle.Format = "C2"; // TL / Para birimi simgesi ekler
            dataGridView1.Columns.Add(fiyatColumn);

            // Kitap Türü Kolonu (tur_ad)

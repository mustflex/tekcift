        private void btnEkle_Click(object sender, EventArgs e)
        {
            KitapView vwKitap = new KitapView();
            if (vwKitap.ShowDialog() == DialogResult.OK)
            {
                // Kitap ekleme işlemi (sp_kitap_ekle)
                var item = uow.KitapRepository.Add(vwKitap.Kitap);
                Kitaplar.Add(item);
                KitaplarSource.ResetBindings(false);
            }
        }

        private void btnGuncelle_Click(object sender, EventArgs e)
        {
            if (dataGridView1.SelectedRows.Count > 0)

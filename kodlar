using MustafaBayram.VarlikKatmani.Base;
using MustafaBayram.VeritabaniErisimKatmani.Repositories.BaseRepositories;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace MustafaBayram.VeritabaniErisimKatmani.Repositories
{
    public abstract class Repository<T> : IRepository<T> where T : IModel
    {
        protected readonly AppDbContext context;
        public abstract string ListProcName { get; }
        public abstract string AddProcName { get; }
        public abstract string DeleteProcName { get; }
        public abstract string UpdateProcName { get; }

        protected Repository(AppDbContext context)
        {
            this.context = context;
        }

        public List<T> ToList()
        {
            var command = context.CreateCommand(ListProcName);
            return context.ToList<T>(command);
        }

        public T Add(T item)
        {
            var command = context.CreateCommand(AddProcName, item.GetInsertParameters());
            item.Id = Convert.ToInt32(context.ExecuteScalar(command));
            return item;
        }

        public int Delete(T item)
        {
            var command = context.CreateCommand(DeleteProcName,item.GetDeleteParameters());
            return context.ExeucteNonQuery(command);
        }

        public int Update(T item)
        {
            var command = context.CreateCommand(UpdateProcName,item.GetUpdateParameters());
            return context.ExeucteNonQuery(command);
        }
    }
}



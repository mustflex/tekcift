    public partial class KitapView : Form
    {
        private readonly UnitOfWork uow = new UnitOfWork();

        public Kitap Kitap { get; set; }

        public KitapView() : this(new Kitap()) { }

        public KitapView(Kitap item)
        {
            InitializeComponent();
            this.Kitap = item;

            // tblTurler listesini çeker. ValueMember -> tur_id, DisplayMember -> tur_ad
            cbxTur.DataSource = uow.TurRepository.ToList();
            cbxTur.ValueMember = "Id"; // Varlık katmanındaki tur_id karşılığı (Id veya TurId olabilir)
            cbxTur.DisplayMember = "Ad"; // Varlık katmanındaki tur_ad karşılığı (Ad veya TurAd olabilir)
        }

        private void KitapView_Load(object sender, EventArgs e)
        {
            // Veri tabanı tablonuzdaki kolonlara göre atamalar (tblKitaplar)
            txtAd.Text = Kitap.Ad;                // kitap_ad
            txtYazar.Text = Kitap.Yazar;          // kitap_yazar
            txtFiyat.Text = Kitap.Fiyat.ToString(); // kitap_fiyat

            cbxTur.SelectedValue = Kitap.Tur != null ? Kitap.Tur.Id : 0; // tur_id
        }

        private void btnTamam_Click(object sender, EventArgs e)
        {
            // Validation (Doğrulama işlemleri yapılabilir)
            if (string.IsNullOrEmpty(txtAd.Text.Trim()) || string.IsNullOrEmpty(txtYazar.Text.Trim()))
            {
                MessageBox.Show("Lütfen boş alanları doldurunuz.", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            // Formdaki verileri Kitap nesnesine aktarıyoruz (sp_kitap_ekle / sp_kitap_guncelle parametreleri için)
            Kitap.Ad = txtAd.Text.Trim();
            Kitap.Yazar = txtYazar.Text.Trim();
            Kitap.Fiyat = Convert.ToDecimal(txtFiyat.Text);
            Kitap.Tur = cbxTur.SelectedItem as Tur;

            this.DialogResult = DialogResult.OK;
        }
    }
}


using MustafaBayram.VeritabaniErisimKatmani.Repositories;
using MustafaBayram.VeritabaniErisimKatmani.Repositories.BaseRepositories;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace MustafaBayram.VeritabaniErisimKatmani
{
    public class UnitOfWork
    {
        private readonly AppDbContext context;


        private ITurRepository _turRepository;
        public ITurRepository TurRepository
        {
            get
            {
                if (_turRepository == null)
                    _turRepository = new TurRepository(context);
                return _turRepository;
            }
        }


        private IKitapRepository _kitapRepository;
        public IKitapRepository KitapRepository
        {
            get
            {
                if (_kitapRepository == null)
                    _kitapRepository = new KitapRepository(context);
                return _kitapRepository;
            }
        }


        private IKullaniciRepository _kullaniciRepository;
        public IKullaniciRepository KullaniciRepository
        {
            get
            {
                if (_kullaniciRepository == null)
                    _kullaniciRepository = new KullaniciRepository(context);
                return _kullaniciRepository;
            }
        }


        public UnitOfWork()
        {
            context = new AppDbContext();
        }

    }
}


